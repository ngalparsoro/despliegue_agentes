# LLM obligatorio
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
CLASSIFICATION_MIN_CONFIDENCE=0.80

# Composio y Gmail
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=mitumi_correo_pruebas
GMAIL_QUERY=is:unread in:inbox newer_than:7d
MAX_EMAILS_PER_RUN=5

# Acciones permitidas
ALLOW_CREATE_DRAFTS=True
REQUIRE_THREAD_FOR_DRAFT=True
ALLOW_MARK_AS_READ=True
ALLOW_EMAIL_SEND=False

# Trazas
SHOW_STEPS=True
