# ============================================================
# AGENTE
# ============================================================
AGENT_NAME=agente_telegram_ponentes
TIMEZONE=Europe/Madrid

# ============================================================
# LLM
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=30

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_ENABLED=True
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT=10
TELEGRAM_REQUEST_TIMEOUT=15
TELEGRAM_CHECK_SECONDS=1
ALLOW_SEND_TELEGRAM=True

# ============================================================
# POSTGRESQL / NEON
# ============================================================
DATABASE_URL=
DB_CONNECT_TIMEOUT_SECONDS=10
EVENT_ACTIVE_STATES=Planificado,Reservado,Confirmado
ALLOW_DB_READ=True

# ============================================================
# SERVICIO LOCAL
# ============================================================
ORDINARY_START_HOUR=7
ORDINARY_END_HOUR=23
SERVICE_LOOP_SECONDS=1
QUIET_MODE_ENABLED=True

# ============================================================
# ADMINISTRADOR
# ============================================================
ADMIN_TELEGRAM_CHAT_ID=
ALLOW_NOTIFY_ADMIN=True

# ============================================================
# ESCALADO
# ============================================================
ESCALATE_UNKNOWN_SPEAKER=True
ESCALATE_MULTIPLE_ACTIVE_EVENTS=True
ESCALATE_MISSING_DATA=True
ESCALATE_LOW_CONFIDENCE=True
MIN_CONFIDENCE_TO_REPLY=0.75

# ============================================================
# RUTAS Y LOGS
# ============================================================
DATA_DIR=data
OUTPUTS_DIR=outputs
LOG_DIR=logs
SHOW_STEPS=True
SAVE_CONVERSATION_LOG=True
