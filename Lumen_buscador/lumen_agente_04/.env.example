# .env.example — plantilla de configuracion de Lumen (Agente 04 - Copilot).
# Copia este archivo a .env y rellena los valores reales:  cp .env.example .env
# NUNCA pongas secretos reales aqui: .env.example SI se versiona; .env NO (esta en .gitignore).

ENVIRONMENT=local

# --- LLM (Groq, API compatible con OpenAI) ---------------------------------------------------
LLM_PROVIDER=groq
# Limite de tokens/dia (plan gratuito de Groq):
#   llama-3.3-70b-versatile -> 100.000 TPD (mas capaz, por defecto)
#   llama-3.1-8b-instant    -> 500.000 TPD (5x, si hay mucho volumen)
#   gemma2-9b-it            -> 500.000 TPD (alternativa)
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
GROQ_API_KEY=poner_api_key_aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Permisos del agente - NO NEGOCIABLES (ademas se fuerzan en config/permisos.py) ----------
ALLOW_DB_WRITE=False
ALLOW_EXTERNAL_SEND=False
ALLOW_CREATE_EVENT=False
ALLOW_AUTO_APPROVAL=False

# --- Base de datos real (Postgres/Neon) - FUENTE UNICA de datos, solo lectura ----------------
# Formato: postgresql://usuario:password@host/basedatos?sslmode=require
# Dejar vacio para ejecutar sin BD (Lumen devolvera un bloqueo explicito en vez de inventar).
DATABASE_URL=
DATABASE_ROLE=readonly

# Tablas excluidas explicitamente (defensa en profundidad; ademas fijado en config/permisos.py)
TABLAS_EXCLUIDAS=usuarios

# --- servidor.py (API HTTP para el frontend React) -------------------------------------------
FLASK_DEBUG=false   # debug del reloader de Flask. OFF por defecto (el debugger de Werkzeug es RCE si se expone)
PORT=5001           # puerto de la API HTTP
SESION_TTL_HORAS=6  # horas de inactividad antes de borrar sola una sesion de chat abandonada

# --- Clasificador LLM de respaldo (src/nucleo.py, prompts/prompt_clasificar_consulta.md) -----
# Solo actua cuando la clasificacion determinista por palabras clave no reconoce nada en una
# pregunta sin id_evento (ver README). Nunca genera SQL ni datos, solo una etiqueta cerrada.
# Poner en false para forzar determinismo total (p. ej. en pruebas automatizadas repetibles).
CLASIFICADOR_LLM_RESPALDO=true

# --- Rutas locales (opcionales) --------------------------------------------------------------
LOG_LEVEL=INFO
