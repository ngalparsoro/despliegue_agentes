# =====================================================================
# AGENTES_EVENTOS — .ENV COMÚN (un solo fichero para todo el repo)
# =====================================================================
# Copia este archivo a .env en esta misma carpeta y rellena tus valores.
# El script arrancar_todo.sh exporta estas variables ANTES de lanzar cada
# servicio, y como load_dotenv() no pisa variables ya presentes en el
# entorno, este fichero MANDA sobre los .env locales de cada agente
# (que siguen sirviendo para arrancar un agente suelto).
#
# .env está en el .gitignore: NUNCA se sube ni se comparte por chats.
# Lo que circula entre el equipo es este .env.example.
# =====================================================================

# ----- Base de datos (Neon Postgres, SOLO LECTURA) -------------------
# Cadena del rol agente_readonly — pedírsela a Nora. NUNCA la del owner.
# La usan: Operis (histórico de eventos), Hermes (datos de ponentes) y
# el backend de agentes :5004.
DATABASE_URL=

# ----- Groq (LLM de Lumen, Operis, Jano y Vigil) ---------------------
# API key de https://console.groq.com — cada desarrollador usa la suya.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq          # lo usa Lumen para elegir proveedor

# ----- Hermes (bot de Telegram) y Garum (gestor de correos) ----------
# Ambos nombran sus variables LLM_* (también es Groq, con base_url OpenAI).
# Si LLM_API_KEY se deja vacía, se rellena con GROQ_API_KEY al arrancar.
LLM_API_KEY=
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# ----- Garum: Gmail vía Composio (https://composio.dev) --------------
# Sin estas claves, el ciclo de Garum falla de forma controlada.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=mitumi_correo_pruebas

# ----- Puertos (mapa canónico del sistema — no cambiar sin avisar) ---
# 3000 backend Express (full stack) · 5000 mock API_Nora · 5001 Lumen
# 5002 Operis · 5003 gateway de data · 5004 backend de agentes
# 8000 Vigil · 8001 Jano
# OJO: no definir aquí una variable PORT global — la leen tanto el
# backend (5004) como Lumen (5001) y chocarían; arrancar_todo.sh se la
# pasa a cada uno en su línea de arranque.
PUERTO_GATEWAY=5003
HOST=127.0.0.1

# ----- CORS (front en otro puerto/dominio) ---------------------------
# En demo local "*" vale; cuando el front esté en Vercel, poner su URL.
MERCURIO_CORS_ORIGINS=*
VIGIL_CORS_ORIGINS=*

# ----- Salidas locales (opcional, por defecto cada agente usa la suya)
# MERCURIO_OUTPUT_DIR=
# VIGIL_OUTPUT_DIR=
# VIGIL_DB_PATH=
