# =====================================================================
# AGENTE OPERIS - VARIABLES DE ENTORNO
# =====================================================================
# Copia este archivo a .env y rellena tus valores.
# .env está en .gitignore, así que NUNCA se sube al repositorio.
# =====================================================================

# ----- GROQ (único motor de extracción) -----
# Obtén tu API key en: https://console.groq.com
# Es OBLIGATORIA para que el agente funcione (el motor de reglas se
# eliminó -- ver README.md, "Motor de extracción").
GROQ_API_KEY=

# Modelo de Groq a usar (opcional)
# Por defecto: openai/gpt-oss-120b
# Otros modelos disponibles: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.
GROQ_MODEL=openai/gpt-oss-120b

# ----- BD real (Neon Postgres), solo lectura (opcional) -----
# Cadena del rol agente_readonly -- pídesela a Nora. NUNCA la de neondb_owner.
# Ver kit_conexion_agentes_Nora/README.md (DESAFIO_MITUMI/) para el procedimiento
# completo. Sin esto, el agente funciona igual, solo que no autocarga el
# histórico de un evento desde la BD real ni verifica id_evento contra ella.
DATABASE_URL=


# =====================================================================
# NOTAS SOBRE SEGURIDAD
# =====================================================================
# 1. NUNCA subas .env al repositorio (está en .gitignore)
# 2. NUNCA compartas tu API key por canales inseguros
# 3. Si crees que tu API key ha sido comprometida, revócala en console.groq.com
# 4. Cada desarrollador debe tener su propio .env con su propia API key
